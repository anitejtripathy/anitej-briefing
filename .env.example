# Copy to .env — never commit .env

# Path to local clone of anitej-briefing-data repo
DATA_REPO_PATH=/Users/anitej.tripathy/anitej-briefing-data

# Google OAuth — download credentials.json from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=/Users/anitej.tripathy/anitej-briefing/credentials.json
GOOGLE_TOKEN_PATH=/Users/anitej.tripathy/anitej-briefing/token.json

# Anitej's email address
USER_EMAIL=anitej.tripathy@razorpay.com

# Fine-grained GitHub PAT — only needed for local development
GITHUB_PAT=github_pat_xxxx
GITHUB_DATA_REPO=anitejtripathy/anitej-briefing-data
